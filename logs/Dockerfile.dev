# Dev image for `devspace dev` (task cluster:watch). Runs the aggregator with
# `go run .` from source that DevSpace syncs in from the host. On each change
# DevSpace restarts the container (devspace.yaml dev.logs.sync.onUpload.
# restartContainer), so `go run` recompiles — i.e. hot reload.
FROM golang:1.25-alpine
RUN apk add --no-cache git
WORKDIR /src
# Pre-download modules into the image cache so restarts only recompile our code.
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ENV PORT=8091
EXPOSE 8091
CMD ["go", "run", "."]
